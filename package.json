{
  "name": "outbound-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "prisma generate && next build",
    "start": "next start",
    "start:role": "node scripts/start-role.mjs",
    "lint": "eslint src prisma --ext .ts,.tsx",
    "test:e2e:deliverability": "tsx scripts/e2e-deliverability.ts",
    "worker": "tsx src/workers/email-worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "setup:demo": "npm run db:migrate && npm run db:seed",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
