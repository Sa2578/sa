generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                   @id @default(cuid())
  name                   String?
  email                  String                   @unique
  passwordHash           String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  domains                Domain[]
  campaigns              Campaign[]
  monitoringMailboxes    MonitoringMailbox[]
  googlePostmasterAccount GooglePostmasterAccount?
}

model Domain {
  id              String       @id @default(cuid())
  domainName      String       @unique
  status          DomainStatus @default(ACTIVE)
  spfValid        Boolean      @default(false)
  dkimValid       Boolean      @default(false)
  dmarcValid      Boolean      @default(false)
  dkimSelectors   Json?
  spfRecord       String?
  dmarcRecord     String?
  mxRecords       Json?
  dnsCheckReport  Json?
  dnsLastCheckedAt DateTime?
  dnsLastError    String?
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  inboxes         Inbox[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
}

enum DomainStatus {
  ACTIVE
  WARMUP
  FLAGGED
  PAUSED
}

model Inbox {
  id                String       @id @default(cuid())
  emailAddress      String       @unique
  domainId          String
  domain            Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  senderName        String?
  replyToEmail      String?
  smtpHost          String
  smtpPort          Int          @default(587)
  smtpUser          String
  smtpPass          String
  lastSmtpVerifiedAt DateTime?
  smtpLastError     String?
  dailyLimit        Int          @default(50)
  sentToday         Int          @default(0)
  warmupStatus      WarmupStatus @default(NONE)
  reputationScore   Float        @default(100)
  isActive          Boolean      @default(true)
  emailLogs         EmailLog[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([domainId])
}

model MonitoringMailbox {
  id              String                  @id @default(cuid())
  userId          String
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress    String
  provider        String
  usage           MonitoringMailboxUsage  @default(PLACEMENT)
  imapHost        String?
  imapPort        Int                     @default(993)
  imapSecure      Boolean                 @default(true)
  imapUser        String
  imapPass        String
  inboxFolderHint String?
  spamFolderHint  String?
  notes           String?
  isActive        Boolean                 @default(true)
  lastCheckedAt   DateTime?
  lastCheckError  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([userId, emailAddress])
  @@index([userId, isActive])
}

enum WarmupStatus {
  NONE
  IN_PROGRESS
  COMPLETED
}

enum MonitoringMailboxUsage {
  PLACEMENT
  FEEDBACK_LOOP
  BOTH
}

model Lead {
  id         String     @id @default(cuid())
  email      String
  name       String?
  company    String?
  status     LeadStatus @default(NEW)
  campaignId String?
  campaign   Campaign?  @relation(fields: [campaignId], references: [id])
  emailLogs  EmailLog[]
  createdAt  DateTime   @default(now())

  @@unique([email, campaignId])
  @@index([campaignId])
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  subject         String
  bodyTemplate    String
  status          CampaignStatus @default(DRAFT)
  isSystem        Boolean        @default(false)
  sendingSchedule Json?
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  leads           Lead[]
  emailLogs       EmailLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model EmailLog {
  id                String       @id @default(cuid())
  leadId            String
  lead              Lead         @relation(fields: [leadId], references: [id])
  inboxId           String
  inbox             Inbox        @relation(fields: [inboxId], references: [id])
  campaignId        String
  campaign          Campaign     @relation(fields: [campaignId], references: [id])
  subject           String
  body              String
  status            EmailStatus  @default(QUEUED)
  messageId         String?
  providerMessageId String?
  smtpResponse      String?
  failureReason     String?
  bounceType        String?
  latestEventType   String?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  deliveredAt       DateTime?
  spamAt            DateTime?
  repliedAt         DateTime?
  sentAt            DateTime?
  lastEventAt       DateTime?
  createdAt         DateTime     @default(now())
  events            EmailEvent[]

  @@index([inboxId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([sentAt])
  @@index([messageId])
  @@index([providerMessageId])
  @@index([latestEventType])
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  SPAM
  FAILED
}

model Alert {
  id         String   @id @default(cuid())
  type       String
  severity   String
  message    String
  entityType String
  entityId   String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([resolved])
  @@index([entityType, entityId])
}

model EmailEvent {
  id                String    @id @default(cuid())
  emailLogId        String
  emailLog          EmailLog  @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  eventType         String
  source            String
  occurredAt        DateTime?
  receivedAt        DateTime  @default(now())
  messageId         String?
  providerMessageId String?
  payload           Json?

  @@index([emailLogId, receivedAt])
  @@index([eventType])
}

model GooglePostmasterAccount {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail          String?
  encryptedRefreshToken String
  encryptedAccessToken String?
  accessTokenExpiresAt DateTime?
  tokenType            String?
  scope                String?
  lastSyncedAt         DateTime?
  lastSyncError        String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  domains              GooglePostmasterDomain[]
}

model GooglePostmasterDomain {
  id                  String                      @id @default(cuid())
  accountId           String
  account             GooglePostmasterAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  domainName          String
  resourceName        String                      @unique
  permission          String
  lastSyncedAt        DateTime?
  lastSyncError       String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  trafficStats        GooglePostmasterTrafficStat[]

  @@unique([accountId, domainName])
  @@index([accountId])
}

model GooglePostmasterTrafficStat {
  id                          String                 @id @default(cuid())
  postmasterDomainId          String
  postmasterDomain            GooglePostmasterDomain @relation(fields: [postmasterDomainId], references: [id], onDelete: Cascade)
  resourceName                String
  statDate                    DateTime
  domainReputation            String?
  userReportedSpamRatio       Float?
  userReportedSpamRatioLowerBound Float?
  userReportedSpamRatioUpperBound Float?
  spfSuccessRatio             Float?
  dkimSuccessRatio            Float?
  dmarcSuccessRatio           Float?
  outboundEncryptionRatio     Float?
  inboundEncryptionRatio      Float?
  deliveryErrors              Json?
  ipReputations               Json?
  spammyFeedbackLoops         Json?
  rawPayload                  Json?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  @@unique([postmasterDomainId, statDate])
  @@index([statDate])
  @@index([postmasterDomainId])
}
